name: E2E (Playwright)

# Démarré manuellement pour l'instant (workflow_dispatch) : la stack tourne DANS
# le runner (backend SQLite + build front servi par le backend), sans LAN. À
# basculer en garde de PR (on: pull_request) une fois validé (cf. échange E03).
on:
  workflow_dispatch:

jobs:
  e2e:
    runs-on: ubuntu-latest
    timeout-minutes: 25
    steps:
      - uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      - name: Install backend deps
        run: pip install -r serveur/requirements.txt

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Build frontend (e2e)
        working-directory: client/src/frontend
        env:
          BUILD_PATH: build-e2e
          REACT_APP_API_URL: /api
          CI: 'false'
        run: |
          npm install
          npm run build

      - name: Install Playwright + Chromium
        working-directory: e2e
        run: |
          npm install
          npx playwright install --with-deps chromium

      - name: Run E2E
        working-directory: e2e
        run: npx playwright test

      - name: Upload Playwright report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: playwright-report
          path: e2e/playwright-report
          retention-days: 7
