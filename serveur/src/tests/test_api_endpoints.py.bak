# ============================================================================
# Database Setup for Tests
# ============================================================================

# Use SQLite for testing (faster, in-memory)
SQLALCHEMY_TEST_DATABASE_URL = "sqlite:///:memory:"

from sqlalchemy.pool import StaticPool

engine = create_engine(
    SQLALCHEMY_TEST_DATABASE_URL,
    connect_args={"check_same_thread": False},
    poolclass=StaticPool,
)

TestingSessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=engine)

# CREATE ALL TABLES IMMEDIATELY (after models are imported)
Base.metadata.create_all(bind=engine)

from fastapi.testclient import TestClient
from src.backend.app import app


def override_get_db():
    """Override database dependency for testing"""
    try:
        db = TestingSessionLocal()
        yield db
    finally:
        db.close()


# Override both bom.get_db and database.get_db
from src.backend.database import get_db as db_get_db
from src.backend.routes.bom import bom_file_service, get_db as bom_get_db

app.dependency_overrides[bom_get_db] = override_get_db
app.dependency_overrides[db_get_db] = override_get_db

# Create test client
client = TestClient(app)


# Fixture for cleanup
@pytest.fixture(scope="function", autouse=True)
def cleanup_db():
    """Reset the database before and after each test."""
    Base.metadata.drop_all(bind=engine)
    Base.metadata.create_all(bind=engine)
    yield
    Base.metadata.drop_all(bind=engine)
    Base.metadata.create_all(bind=engine)


