# Optional local override for quick dev/testing
# Example: DATABASE_URL=sqlite:///./database/dev.db
DATABASE_URL=

# SQL Server Connection
SQL_SERVER_HOST=localhost
SQL_SERVER_PORT=1433
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=changeme
SQL_SERVER_DATABASE=ECB_Production
SQL_SERVER_DRIVER=ODBC Driver 17 for SQL Server

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# File Paths
BOM_IMPORT_FOLDER=./uploads/bom
EXPORT_FOLDER=./exports
DATABASE_BACKUP_FOLDER=./backups

# CORS (Frontend URLs)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Supplier APIs (ADR 0004). Real secrets go in serveur/.env (gitignored), never here.
FARNELL_API_URL=
FARNELL_API_KEY=

RS_API_URL=
RS_API_KEY=

# Mouser — API key in query string. Get it from your My Mouser account.
MOUSER_API_URL=https://api.mouser.com/api/v1
MOUSER_API_KEY=

# DigiKey — OAuth2 2-legged (client credentials). Create an app at
# https://developer.digikey.com/ (Product Information V4) to get id + secret.
DIGIKEY_API_URL=https://api.digikey.com
DIGIKEY_OAUTH_URL=https://api.digikey.com/v1/oauth2/token
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
DIGIKEY_LOCALE_SITE=FR
DIGIKEY_LOCALE_CURRENCY=EUR
DIGIKEY_LOCALE_LANGUAGE=fr

# Supplier offers cache freshness (hours)
SUPPLIER_OFFER_TTL_HOURS=24

# ERP export default values (editable in-app via the admin screen)
ERP_DEFAULT_PROJECT=PJ2601-00241 - Achat projet client 2026
ERP_DEFAULT_UNIT=pièce
ERP_DEFAULT_REQUESTER=Eric Bouquet
ERP_DEFAULT_VALIDATOR=Kevin Surrier
ERP_DEFAULT_DELAY=URGENT
ERP_DEFAULT_REMARK=mise en bobine
