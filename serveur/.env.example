# Optional local override for quick dev/testing
# Example: DATABASE_URL=sqlite:///./database/dev.db
DATABASE_URL=

# SQL Server Connection
SQL_SERVER_HOST=localhost
SQL_SERVER_PORT=1433
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=changeme
SQL_SERVER_DATABASE=ECB_Production
SQL_SERVER_DRIVER=ODBC Driver 17 for SQL Server

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# File Paths
BOM_IMPORT_FOLDER=./uploads/bom
EXPORT_FOLDER=./exports
DATABASE_BACKUP_FOLDER=./backups

# CORS (Frontend URLs)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Phase 2 - Supplier APIs (leave empty for now)
FARNELL_API_URL=
FARNELL_API_KEY=

DIGIKEY_API_URL=
DIGIKEY_API_KEY=

RS_API_URL=
RS_API_KEY=

MOUSER_API_URL=
MOUSER_API_KEY=
