{
  "name": "pcb-flow-production-suite",
  "version": "1.0.4",
  "description": "PCB Flow Production Suite - Desktop App",
  "author": "ECB",
  "main": "src/main.js",
  "homepage": "./",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^24.6.4",
    "electron-devtools-installer": "^3.2.0"
  },
  "scripts": {
    "start": "electron .",
    "start:web": "npm --prefix ../frontend start",
    "build:renderer": "npm --prefix ../frontend run build",
    "build:desktop": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder",
    "build:portable": "npm run build:renderer && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --publish never --win portable",
    "build": "npm run build:renderer && npm run build:desktop",
    "dist": "npm run build:renderer && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --publish never",
    "dist:portable": "npm run build:renderer && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --publish never --win portable",
    "dist:signed": "npm run build:renderer && electron-builder --publish never",
    "publish:signed": "npm run build:renderer && electron-builder --publish always",
    "publish": "npm run build:renderer && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --publish always"
  },
  "build": {
    "appId": "com.ecb.production",
    "productName": "PCB Flow Production Suite",
    "publish": {
      "provider": "github",
      "owner": "SkaberOne",
      "repo": "PCB-Production-V2"
    },
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/build",
        "to": "frontend/build",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../../serveur/dist/pcb-flow-server",
        "to": "pcb-flow-server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "nsis",
        "to": "nsis",
        "filter": [
          "*.ps1"
        ]
      },
      {
        "from": "installers",
        "to": "installers",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "nsis/installer.nsh"
    }
  }
}
