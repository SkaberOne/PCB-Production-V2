# ============================================================
# CONFIGURATION CLIENT - ECB Production Manager
# ============================================================

# --- URL du serveur API ---
# Modifier avec l'IP du serveur si accès réseau (ex: http://192.168.1.50:8000)
REACT_APP_API_URL=http://localhost:8000/api

# --- Port du serveur de dev frontend (npm start) ---
PORT=3000

# --- Clé API (si configurée côté serveur) ---
# REACT_APP_API_KEY=secret123

# --- Dev uniquement : contourne le bug react-scripts 5 + Node recent ---
# (sinon erreur "allowedHosts[0] should be a non-empty string" au demarrage)
DANGEROUSLY_DISABLE_HOST_CHECK=true
