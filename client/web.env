# ============================================================
# CONFIGURATION BUILD WEB — Acces LAN via navigateur
# Utilise par CONSTRUIRE_WEB.bat (copie vers src/frontend/.env avant le build).
# ============================================================

# API en chemin relatif -> meme origine que la page (le backend sert l'UI ET
# l'API sur le meme port). Aucun CORS, aucune IP a coder en dur.
REACT_APP_API_URL=/api

# Cle API : NON bakee dans le build. A la premiere visite, une fenetre demande la
# cle au collegue ; elle est ensuite memorisee dans son navigateur (localStorage).
# La cle exigee est definie cote serveur par API_KEY dans DEMARRER_SERVEUR_WEB.bat.
# (Laisser REACT_APP_API_KEY vide/absent pour que la fenetre s'affiche.)
# REACT_APP_API_KEY=

# Sortie du build web dans build-web/ pour ne PAS ecraser build/ (utilise par le
# packaging desktop / electron).
BUILD_PATH=build-web

# Flags fonctionnalites (aligne sur client.env)
REACT_APP_FEATURE_MACHINE_PNP_PLAN=true
REACT_APP_FEATURE_LIBRARY_STOCK=true
