# ============================================================
# CONFIGURATION CLIENT — PCB Flow Production Suite (MODÈLE)
# ============================================================
# Copier en `client/client.env` (gitignoré) et adapter.
# DEMARRER_CLIENT.bat copie ce fichier vers client/src/frontend/.env.
#
# NB : en mode PACKAGÉ (app installée), l'URL backend et la clé API sont
# injectées au runtime par Electron (port dynamique) — ces variables ne
# servent qu'au développement (navigateur sur http://localhost:3000).

# --- URL du serveur API (DEV uniquement) ---
# IP du serveur si accès réseau, ex: http://192.168.1.50:8000/api
REACT_APP_API_URL=http://localhost:8000/api

# --- Port du serveur de dev frontend (npm start) ---
PORT=3000

# --- Clé API (DEV uniquement, si le backend dev en exige une) ---
# REACT_APP_API_KEY=

# --- DEV uniquement : contourne le bug react-scripts 5 + Node récent ---
# (sinon « allowedHosts[0] should be a non-empty string » au démarrage)
# N'affecte PAS le build de production (variable non REACT_APP_, non bakée).
DANGEROUSLY_DISABLE_HOST_CHECK=true

# --- Feature flags (fonctionnalités en cours) ---
# Activer le plan d'implantation feeders (en cours de dev).
REACT_APP_FEATURE_MACHINE_PNP_PLAN=false
