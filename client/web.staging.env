# ============================================================
# CONFIGURATION BUILD WEB STAGING — Instance de test (:8001)
# Utilise par CONSTRUIRE_WEB_STAGING.bat (copie vers src/frontend/.env avant le build).
# Identique a web.env SAUF le dossier de sortie (build-web-staging) pour ne pas
# ecraser le build de prod (build-web).
# ============================================================

# API en chemin relatif -> meme origine que la page (le backend staging sert l'UI
# ET l'API sur le meme port 8001).
REACT_APP_API_URL=/api

# Cle API : saisie par l'utilisateur a la premiere visite (fenetre ApiKeyGate),
# memorisee dans le navigateur. Cote serveur staging la cle exigee est
# pcbflow-staging (definie dans serveur/DEMARRER_SERVEUR_WEB_STAGING.bat).
# REACT_APP_API_KEY=

# Sortie du build dans build-web-staging/ (ne PAS ecraser build-web ni build).
BUILD_PATH=build-web-staging

# Flags fonctionnalites (aligne sur web.env)
REACT_APP_FEATURE_MACHINE_PNP_PLAN=true
REACT_APP_FEATURE_LIBRARY_STOCK=true
