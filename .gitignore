# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.installed.cfg
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# venv (LOI: garder a la racine du projet)
.venv/
venv/
ENV/
env/

# --- Node / React ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# --- Build artifacts ---
build/
dist/
*.tsbuildinfo
# .NET launcher (si réintroduit)
serveur/launcher/bin/
serveur/launcher/obj/
# Exécutables de launcher (générés)
LANCER_*.exe
*.exe

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- OS ---
.DS_Store
Thumbs.db

# --- Environment ---
.env
.env.local
.env.*.local
# Garder .env.example (modele)
!serveur/.env.example

# --- Logs ---
logs/
*.log

# --- Uploads / Exports / Backups (runtime) ---
serveur/uploads/
serveur/exports/
serveur/backups/

# --- Secrets identifiants API fournisseurs (jamais committer) ---
serveur/data/supplier_credentials.json

# --- Datasheets PDF source (lourd, propriété fournisseur) — ADR 0003 ---
data/datasheets/pdf/*
!data/datasheets/pdf/.gitkeep

# --- Database ---
*.mdb
*.db
*.sqlite
*.sqlite3

# --- Project specific ---
.cache/
temp/
*.bak
*.bak_*
/exports/
*.db-journal
*.db-wal
*.db-shm
*/migrations/versions/__pycache__/

# --- Obsidian vault ---
# Versionner la config minimale et les plugins, ignorer le workspace personnel
.obsidian/workspace.json
.obsidian/workspaces.json
.obsidian/cache
.obsidian/graph.json
docs/attachments/

# Artefacts temporaires build/publish
client/publish*.log
client/*_done.txt
client/eb_*.log

# Binaires installeurs tiers embarqués (ADR 0009) — redistribuables Microsoft,
# récupérés au build du Host, jamais versionnés (le README reste suivi).
client/src/desktop/installers/*.msi
client/src/desktop/installers/*.exe

# Certificats de signature (ADR 0009 #5) - jamais versionnes
*.pfx
*.cer

# runtime server/frontend logs (never commit)
*.err
*.log
serveur/backend.err
client/src/frontend/frontend.err
